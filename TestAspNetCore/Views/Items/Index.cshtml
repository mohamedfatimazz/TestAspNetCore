@model IEnumerable<Item>
@{
    ViewData["Title"] = "Items Page";
}
<div class="container p-3 bg-body-secondary">
    <partial name="_Notifications" />
    <div class="row pt-4">
        <div class="col-6"><h2>Items View</h2></div>
        <div class="col-6 text-end "><a asp-controller="Items" asp-action="New" class="btn btn-dark"> <i class="bi bi-plus-circle-fill"></i>&nbsp; Add New Item</a></div>
    </div>
    <table class="table table-hover">
        <thead>
            <tr>
                <th scope="col">Name</th>
                <th scope="col">Price</th>
                <th scope="col">Categore</th>
                <th scope="col">Img</th>
                <th scope="col"></th>
                <th scope="col"></th>

            </tr>
        </thead>
        <tbody>
            @if (Model == null)
            {
                <tr>
                    <td colspan="2">No items found.</td>
                </tr>
                return;
            }
            @foreach (var item in Model)
            {
                <tr class="table-dark">
                    <td scope="row" width="30%">@item.Name</td>
                    <td scope="row" width="20%">@item.Price</td>
                    <td scope="row" width="30%">@item.Categorecs.Name</td>
                    <td scope="row">
                        <img src="~/Images/@item.ImagePath" style="width:48px"class="img-thumbnail" />
                    </td>
                    <td scope="row"><a asp-controller="Items" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-success"><i class="bi bi-pencil-fill"></i></a></td>
                    <td scope="row"><a asp-controller="Items" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-primary"><i class="bi bi-trash3-fill"></i></a></td>
                    
                </tr>
            }

        </tbody>
    </table>
</div>

