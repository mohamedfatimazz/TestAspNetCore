@model Item
@{
    ViewData["Title"] = "Delete";
}
<form method="post" asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <div class="border p-3 mt-4 bg-body-secondary " style="background-color:lightslategray ">
        <div class="row pb-2">
            <h2 class="text-bg-dark">Delete Item</h2>
            <hr />
        </div>
        <div asp-validation-summary="All"></div>
        <div class="mb-3">
            <label asp-for="Name"></label>
            <input asp-for="Name" disabled class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Price"></label>
            <input asp-for="Price" disabled class="form-control" />
        </div>
        <div>
            <label asp-for="CatogoreId"></label>
            <select asp-for="CatogoreId" disabled class="form-control" asp-items="@ViewBag.Categorecs"> </select>
            <span asp-validation-for="CatogoreId" class="text-bg-danger"></span>
        </div>
        <div>
            <img id="myImg" src="~/Images/@Model.ImagePath" +" height="200" />
        </div>
        <hr />
        <br />
        <button type="submit" class="btn btn-success" style="width:150px"> Delete </button>
        <a asp-action="Index" asp-controller="Items" class="btn btn-primary" style="width:150px">back to items</a>
    </div>
</form>