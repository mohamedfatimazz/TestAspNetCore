@model Categore
@{
    ViewData["Titel"] = "Categort View";
}
<form method="post">
    <div class="border p-3 mt-4 bg-body-secondary " style="background-color:lightslategray ">
        <div class="row pb-2">
            <h2 class="text-bg-dark">Edit Categore</h2>
            <hr />
        </div>
        <div asp-validation-summary="All"></div>
        <div class="mb-3">
            <label asp-for="Name"  class=" form-label>"></label>
            <input asp-for="Name" disabled class="form-control">
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div>
            <img id="myImg" src="@Model.ClientFile" +" height="200" />
        </div>
        <br />
        <hr />
        <button type="submit" class="btn btn-success" style="width:150px">Delete </button>
        <a asp-action="Index" asp-controller="Categore" class="btn btn-primary">Back to Categores</a>

    </div>
</form>
@section scripts {
    <partial name="_ValidationScriptsPartial.cshtml" />
}
